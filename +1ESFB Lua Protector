local fadeTexts = {
	"Hello " .. player.Name,
	"Thanks For Using Etherion",
	"Join Our Discord"
}

local fadeLabel = Instance.new("TextLabel")
fadeLabel.Size = UDim2.new(1, -20, 0, 50)
fadeLabel.Position = UDim2.new(0, 10, 0, 35)
fadeLabel.BackgroundTransparency = 1
fadeLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
fadeLabel.Font = Enum.Font.SourceSansSemibold
fadeLabel.TextSize = 25
fadeLabel.TextWrapped = true
fadeLabel.TextTransparency = 1
fadeLabel.Parent = main

task.spawn(function()
	while true do
		for _, txt in ipairs(fadeTexts) do
			fadeLabel.Text = txt
			for i = 1, 0, -0.05 do
				fadeLabel.TextTransparency = i
				task.wait(0.025)
			end
			task.wait(1.5)
			for i = 0, 1, 0.05 do
				fadeLabel.TextTransparency = i
				task.wait(0.025)
			end
		end
	end
end)

